# Copy to .env and fill in your values.
# The binary reads this file automatically from the working directory.
# Real environment variables always take precedence.

# Telegram bot token — get one from @BotFather (/newbot)
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID to send the message to.
# For a personal chat: start a conversation with your bot, then call:
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
# and read $.result[0].message.chat.id
# For a group: add the bot to the group and do the same.
TELEGRAM_CHAT_ID=123456789

# How often to poll for availability. Go duration syntax: 15m, 1h, 30s (default: 15m)
# POLL_INTERVAL=15m
